{
  "$type": "spacing",
  "$extensions": {
    "scaleGenerator": "https://utopia.fyi/space/calculator?c=320,19,1.2,1350,28,1.25,6,2,&s=0.75%7C0.5%7C0.25,2%7C3%7C5%7C8%7C13,s-l&g=s,l,xl,12",
    "note": "shifting the scale: XS is equal to 3XS"
  },
  "3xs": { "$value": { "min": 2, "max": 3 } },
  "2xs": { "$value": { "min": 3, "max": 5 } },
  "xs": { "$value": { "min": 5, "max": 7 } },
  "s": { "$value": { "min": 10, "max": 14 } },
  "m": { "$value": { "min": 14, "max": 21 } },
  "l": { "$value": { "min": 19, "max": 31 } },
  "xl": { "$value": { "min": 38, "max": 56 } },
  "2xl": { "$value": { "min": 57, "max": 84 } },
  "3xl": { "$value": { "min": 95, "max": 140 } },
  "xs-s": { "$value": { "min": 5, "max": 14 } },
  "s-m": { "$value": { "min": 10, "max": 21 } },
  "m-l": { "$value": { "min": 14, "max": 31 } },
  "l-xl": { "$value": { "min": 19, "max": 56 } },
  "l-2xl": { "$value": { "min": 19, "max": 84 } },
  "xl-2xl": { "$value": { "min": 38, "max": 84 } },
  "2xl-3xl": { "$value": { "min": 57, "max": 140 } }
}
